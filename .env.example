# ai-tools secrets — copy to `secrets.env` and fill in. NEVER commit secrets.env.
# The installer symlinks this into your shell profile so Claude Code sees these
# vars at launch and expands ${VAR} references in claude/mcp-servers.json.

# Homelab MCP (Grafana) — the FULL Authorization header value, including any
# "Bearer " prefix. e.g. HOMELAB_MCP_TOKEN="Bearer glsa_xxxxxxxx"
HOMELAB_MCP_TOKEN=""

# HCP Terraform / Terraform Cloud API token (app.terraform.io → Account → Tokens).
# Forwarded into the terraform MCP container via `docker run -e TFE_TOKEN`.
TFE_TOKEN=""

# aws-mcp uses your ambient AWS credentials (SigV4) — no token needed here.
# Make sure `aws sso login` / your AWS profile is active on this machine.
